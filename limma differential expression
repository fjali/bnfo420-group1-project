  "Gipr",     # gip receptor
  "Prkaca",   # camp/pka pathway - catalytic subunit
  "Prkacb",   # camp/pka pathway - catalytic subunit
  "Prkar1a",  # camp/pka pathway - regulatory subunit
  "Prkar2a",  # camp/pka pathway - regulatory subunit
  "Creb1",    # downstream of pka - transcription factor
  "Adcy1",    # adenylyl cyclase - makes camp
  "Adcy2"     # adenylyl cyclase
)


# function: run_limma_comparison
# runs the full limma pipeline for one comparison
# saves results as a csv file for use in the volcano plot script

run_limma_comparison <- function(expr_matrix, meta,
                                 group_col, ref_group, test_group,
                                 comparison_name, data_dir) {
  
  cat("\n--- running:", comparison_name, "---\n")
  
  # subset to only the groups we are comparing
  keep_samples <- meta[[group_col]] %in% c(ref_group, test_group)
  meta_sub     <- meta[keep_samples, ]
  expr_sub     <- expr_matrix[, meta_sub$gsm_id]
  
  cat("samples in comparison:", ncol(expr_sub), "\n")
  cat("reference group:", ref_group, "| test group:", test_group, "\n")
  
  # build design matrix
  # this tells limma which sample belongs to which group
  group    <- factor(meta_sub[[group_col]], levels = c(ref_group, test_group))
  design   <- model.matrix(~ group)
  colnames(design) <- c("Intercept", "GroupEffect")
  
  # step 1: fit linear model to each gene
  fit  <- lmFit(as.matrix(expr_sub), design)
  
  # step 2: apply empirical bayes moderation
  fit2 <- eBayes(fit)
  
  # step 3: extract results for all genes
  results <- topTable(fit2, coef = "GroupEffect",
                      number        = Inf,
                      adjust.method = "BH",
                      sort.by       = "P")
  
  #add significance labels
  results$significance <- "Not Significant"
  results$significance[results$adj.P.Val < 0.05 & results$logFC >  1] <- "Upregulated"
  results$significance[results$adj.P.Val < 0.05 & results$logFC < -1] <- "Downregulated"
  
  # flag hypothesis genes
  results$is_hypothesis_gene <- rownames(results) %in% hypothesis_genes
  results$gene_name          <- rownames(results)
  
  # print summary
  cat("upregulated genes (FDR<0.05, logFC>1):  ",
      sum(results$significance == "Upregulated"), "\n")
  cat("downregulated genes (FDR<0.05, logFC<-1):",
      sum(results$significance == "Downregulated"), "\n")
  
  # print hypothesis gene results
  hyp_found <- results[results$is_hypothesis_gene,
                       c("logFC", "adj.P.Val", "significance")]
  if (nrow(hyp_found) > 0) {
    cat("hypothesis genes found:\n")
    print(hyp_found)
  }
  
  # save results table as csv for volcano plot script
  safe_name <- gsub("[^a-zA-Z0-9]", "_", comparison_name)
  write.csv(results,
            file.path(data_dir, paste0("DEG_", safe_name, ".csv")))
  cat("results saved:", paste0("DEG_", safe_name, ".csv"), "\n")
  
  return(results)
}

